---
import "../styles/global.css";
import { experiments } from "../data/experiments";
import Globe from "../components/Globe.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Steven Chong — Building @ Cloudflare — AI Foundations."
    />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Steven Chong</title>
  </head>
  <body
    class="min-h-screen overscroll-none bg-[#0a0a0a] font-sans text-neutral-100 antialiased"
  >
    <Globe />

    <main
      class="relative z-10 mx-auto flex min-h-screen max-w-xl flex-col justify-center px-6 py-16"
    >
      <h1 class="text-4xl font-semibold tracking-tight">Steven Chong</h1>
      <p class="mt-3 text-neutral-300">
        Building @ <span class="text-[#f38020]">Cloudflare</span> — AI Foundations.
      </p>

      <nav class="mt-8 flex gap-6 text-sm">
        <a
          href="https://github.com/teamchong"
          class="text-neutral-300 underline-offset-4 transition-colors hover:text-[#faad3f] hover:underline"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/teamchong"
          class="text-neutral-300 underline-offset-4 transition-colors hover:text-[#faad3f] hover:underline"
        >
          LinkedIn
        </a>
      </nav>

      {
        experiments.length > 0 && (
          <section class="mt-16">
            <h2 class="mb-6 text-xs uppercase tracking-widest text-neutral-500">
              Experiments
            </h2>
            <ul class="space-y-4">
              {experiments.map((e) => (
                <li>
                  <a
                    href={e.url}
                    class="block rounded-lg border border-neutral-800 bg-neutral-950/60 p-5 backdrop-blur transition-colors hover:border-[#f38020]/60"
                  >
                    <div class="flex items-baseline justify-between gap-4">
                      <h3 class="font-medium">{e.title}</h3>
                      <span class="truncate font-mono text-xs text-neutral-500">
                        {new URL(e.url).host}
                      </span>
                    </div>
                    <p class="mt-2 text-sm text-neutral-400">{e.blurb}</p>
                    {e.tags && (
                      <div class="mt-3 flex flex-wrap gap-2">
                        {e.tags.map((t) => (
                          <span class="font-mono text-xs text-[#faad3f]/70">
                            {t}
                          </span>
                        ))}
                      </div>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </main>
  </body>
</html>
